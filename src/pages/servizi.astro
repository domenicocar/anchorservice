---
import BaseLayout from "../layouts/BaseLayout.astro";
import { services, siteConfig } from "../data/site";
import Button from "../components/ui/Button.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";

const title = "Servizi nautici per barche a vela | Anchor Service Bari";
const description =
  "Rigging, manutenzione yacht, veleria, trasferimenti, ormeggio, gestione, perizie, compravendita e noleggio: scopri i servizi Anchor Service.";
---

<BaseLayout title={title} description={description}>
  <section
    class="bg-anchor-navy px-5 pb-10 pt-32 text-anchor-white md:px-8 md:pb-12 md:pt-36"
  >
    <div class="mx-auto max-w-7xl">
      <p class="mb-5 text-sm font-bold text-anchor-brass">
        Servizi tecnici nautici
      </p>
      <h1 class="max-w-4xl text-5xl font-black leading-[1.04] md:text-7xl">
        Servizi per barche a vela, con il rigging al centro.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-anchor-light-grey">
        Una panoramica degli interventi tecnici disponibili per proprietari,
        cantieri e marine.
      </p>
    </div>
  </section>

  <section class="px-5 py-20 md:px-8">
    <div class="mx-auto max-w-7xl">
      <SectionHeader
        title="Aree di intervento"
        description="Ogni servizio parte da una valutazione concreta dello stato della barca e delle priorita operative."
      />
      <div class="mt-12 grid gap-6">
        {
          services.map((service) => (
            <article
              class:list={[
                "grid gap-5 rounded-anchor border bg-anchor-white p-6 md:grid-cols-[0.35fr_0.65fr] md:p-8",
                service.featured
                  ? "border-anchor-brass shadow-[0_16px_45px_rgb(11_31_51_/_0.08)]"
                  : "border-anchor-light-grey",
              ]}
            >
              <div>
                {service.category && (
                  <p class="text-xs font-semibold uppercase tracking-[0.14em] text-anchor-brass">
                    {service.category}
                  </p>
                )}
                <h2
                  class:list={[
                    "text-2xl font-semibold text-anchor-navy",
                    service.category && "mt-3",
                  ]}
                >
                  {service.title}
                </h2>
              </div>
              <div>
                <p class="text-base leading-7 text-anchor-steel-grey">
                  {service.shortDescription}
                </p>
                <a
                  class="mt-5 inline-flex min-h-11 items-center font-semibold text-anchor-steel-blue hover:text-anchor-navy"
                  href={service.href}
                >
                  Vai al dettaglio
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-anchor-white px-5 py-20 md:px-8">
    <div
      class="mx-auto grid max-w-7xl items-center gap-8 md:grid-cols-[1fr_auto]"
    >
      <SectionHeader
        eyebrow="Quando contattarci"
        title="Prima della stagione, prima di un trasferimento o quando noti usura."
        description="Un controllo programmato aiuta a capire quali interventi sono urgenti e quali possono essere pianificati."
      />
      <div class="flex flex-wrap gap-3 md:justify-end">
        {
          siteConfig.phoneHref && (
            <Button
              href={siteConfig.phoneHref}
              label="Chiama ora"
              variant="secondary"
            />
          )
        }
        <Button href="/#contatti" label="Richiedi informazioni" />
      </div>
    </div>
  </section>
</BaseLayout>
