---
import BaseLayout from "../layouts/BaseLayout.astro";
import { services, siteConfig } from "../data/site";
import Button from "../components/ui/Button.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import ServiceCard from "../components/ui/ServiceCard.astro";
import TechnicalVisual from "../components/sections/TechnicalVisual.astro";
import ContactSection from "../components/sections/ContactSection.astro";

const title = "Anchor Service | Rigging e manutenzione barche a vela a Bari";
const description =
  "Anchor Service si occupa di rigging, standing rigging e manutenzione tecnica per barche a vela a Bari. Richiedi un controllo o un primo contatto tecnico.";

const coursePlans = [
  {
    title: "Base",
    subtitle: "Per iniziare a bordo",
    price: "300&euro;",
    description:
      "Prime manovre, termini e ruoli per muoversi con piu sicurezza in navigazione.",
    image: "/images/Aerial_drone_view_of_a_202606181149.jpeg",
    imageAlt: "Barca a vela durante una navigazione costiera",
    icon: "sail",
    featured: false,
    features: [
      ["Virate e cambio bordo", "Base"],
      ["Abbattute in condizioni semplici", "Base"],
      ["Terminologia di bordo", "Inclusa"],
      ["Ruoli, assetto e comunicazione", "Inclusi"],
      ["Timone, scotte e regolazioni iniziali", "Inclusi"],
    ],
  },
  {
    title: "Medio",
    subtitle: "Per manovre operative",
    price: "700&euro;",
    description:
      "Per chi ha gia le basi e vuole gestire meglio porto, ancoraggio e sicurezza.",
    image: "/images/Luxury_sailing_yacht_gliding_on_202606181209.jpeg",
    imageAlt: "Equipaggio su barca a vela in navigazione",
    icon: "compass",
    featured: true,
    features: [
      ["Ormeggi con cime e parabordi", "Pratica"],
      ["Disormeggi e gestione spazi in porto", "Pratica"],
      ["Ancoraggio e controllo della tenuta", "Incluso"],
      ["Recupero uomo in mare", "Incluso"],
      ["Coordinamento equipaggio", "Incluso"],
    ],
  },
  {
    title: "Avanzato",
    subtitle: "Per condizioni impegnative",
    price: "Su richiesta",
    description:
      "Per consolidare scelte, sicurezza e conduzione quando vento e mare richiedono piu attenzione.",
    image: "/images/apri_le_vele_2K_202606161716.jpeg",
    imageAlt: "Barca a vela in navigazione con equipaggio",
    icon: "waves",
    featured: false,
    features: [
      ["Uscite con mare formato", "Avanzato"],
      ["Gestione vento, onda e cambi programma", "Inclusa"],
      ["Manovre evolute e conduzione precisa", "Inclusa"],
      ["Riduzione vela e controllo equipaggio", "Inclusi"],
      ["Scelte operative e priorita a bordo", "Inclusi"],
    ],
  },
] as const;

const courseIcons = {
  sail: '<svg viewBox="0 0 32 32" aria-hidden="true"><path d="M16 3v24"/><path d="M16 5 7 23h9"/><path d="M17 9l8 14h-8"/><path d="M8 28h17"/></svg>',
  compass:
    '<svg viewBox="0 0 32 32" aria-hidden="true"><circle cx="16" cy="16" r="11"/><path d="m20.5 8.5-2.9 9.1-8.1 5.9 2.9-9.1 8.1-5.9Z"/><path d="m12.4 14.4 5.2 3.2"/></svg>',
  waves:
    '<svg viewBox="0 0 32 32" aria-hidden="true"><path d="M4 18c3 0 3-3 6-3s3 3 6 3 3-3 6-3 3 3 6 3"/><path d="M4 25c3 0 3-3 6-3s3 3 6 3 3-3 6-3 3 3 6 3"/><path d="M11 9c2.5-2.5 7.5-2.5 10 0"/></svg>',
} as const;

const featureIcon =
  '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 5 7v6c0 4.2 2.7 7 7 8 4.3-1 7-3.8 7-8V7l-7-4Z"/></svg>';
---

<BaseLayout title={title} description={description}>
  <section
    class="relative flex min-h-screen overflow-hidden bg-anchor-navy px-5 py-24 text-anchor-white md:px-8"
  >
    <img
      class="absolute inset-0 h-full w-full object-cover"
      src="/images/hero_anchor_service.jpeg"
      alt=""
      width="2048"
      height="1024"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-black/35"></div>
    <div class="relative z-10 mx-auto flex w-full max-w-7xl items-center">
      <div class="max-w-4xl pt-10">
        <h1
          class="max-w-4xl text-5xl font-black leading-[1.02] text-anchor-white md:text-7xl"
        >
          Rigging e manutenzione per barche a vela.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-anchor-light-grey">
          Controlli su sartie, strallo, arridatoi, cime e attrezzatura di
          coperta. Un supporto tecnico concreto per proprietari, cantieri e
          marine.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="#contatti" label="Richiedi controllo" />
          {
            siteConfig.phoneHref && (
              <Button
                href={siteConfig.phoneHref}
                label="Chiama ora"
                variant="secondary"
              />
            )
          }
          <Button href="#contatti" label="Vai ai contatti" variant="ghost" />
          {
            siteConfig.whatsappHref && (
              <Button
                href={siteConfig.whatsappHref}
                label="WhatsApp"
                variant="whatsapp"
              />
            )
          }
        </div>
        <p class="mt-5 text-sm font-bold text-anchor-brass">
          Rigging e assistenza tecnica nautica a Bari
        </p>
      </div>
    </div>
  </section>

  <section class="relative z-10 -mt-20 pb-20">
    <div
      class="w-full overflow-hidden rounded-anchor bg-anchor-white px-5 py-12 shadow-[0_30px_90px_rgb(11_31_51_/_0.10)] md:px-8 md:py-14"
    >
      <SectionHeader
        title="Interventi tecnici per la barca a vela"
        description="Il rigging resta il servizio principale. Le attivita di manutenzione, coperta, vele e consulenza completano il supporto operativo."
        align="center"
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          services.map((service, index) => (
            <ServiceCard service={service} index={index} />
          ))
        }
      </div>
    </div>
  </section>

  <section class="relative z-20 -mt-10 bg-anchor-white px-5 pb-20 pt-8 md:px-8">
    <div class="mx-auto mb-8 max-w-7xl text-center text-anchor-navy">
      <div class="flex flex-wrap items-center justify-center gap-4">
        <img
          class="h-16 w-16 object-contain md:h-20 md:w-20"
          src="/images/anchorserviceexperience.png"
          alt=""
          width="160"
          height="160"
          loading="lazy"
          decoding="async"
          aria-hidden="true"
        />
        <h2 class="text-4xl font-black leading-tight md:text-6xl">
          Sailing Experience
        </h2>
      </div>
      <p
        class="mx-auto mt-5 max-w-2xl text-base leading-7 text-anchor-steel-grey md:text-lg"
      >
        Uscite, trasferimenti e viaggi in barca a vela con supporto tecnico e
        attenzione alla sicurezza dell'equipaggio.
      </p>
    </div>
    <div
      class="relative min-h-[475px] overflow-hidden rounded-anchor bg-anchor-navy text-anchor-white shadow-[0_30px_90px_rgb(11_31_51_/_0.16)] md:min-h-[595px]"
    >
      <img
        class="absolute inset-0 h-full w-full object-cover"
        src="/images/Aerial_drone_view_of_a_202606181149.jpeg"
        alt=""
        width="1920"
        height="1080"
        loading="lazy"
        decoding="async"
        aria-hidden="true"
      />
      <img
        class="sailing-crossfade absolute inset-0 h-full w-full object-cover"
        src="/images/Luxury_sailing_yacht_gliding_on_202606181209.jpeg"
        alt=""
        width="1920"
        height="1080"
        loading="lazy"
        decoding="async"
        aria-hidden="true"
      />
      <div
        class="absolute inset-0 bg-gradient-to-l from-anchor-navy/45 via-anchor-navy/20 to-transparent"
      >
      </div>
      <div
        class="relative z-10 flex min-h-[475px] items-end p-6 md:min-h-[595px] md:items-center md:p-10"
      >
        <div class="relative ml-auto min-h-64 w-full max-w-xl">
          <div class="sailing-copy sailing-copy-greece absolute inset-0">
            <h3 class="text-4xl font-black leading-tight md:text-6xl">
              Grecia
            </h3>
            <p
              class="mt-5 max-w-lg text-base leading-7 text-anchor-light-grey md:text-lg"
            >
              Navigazioni tra isole, porti e rade, con pianificazione tecnica e
              gestione attenta delle tratte.
            </p>
            <div class="mt-6">
              <Button href="#contatti" label="Richiedi preventivo" />
            </div>
          </div>
          <div class="sailing-copy sailing-copy-croatia absolute inset-0">
            <h3 class="text-4xl font-black leading-tight md:text-6xl">
              Croazia
            </h3>
            <p
              class="mt-5 max-w-lg text-base leading-7 text-anchor-light-grey md:text-lg"
            >
              Rotte costiere, trasferimenti e assistenza alla navigazione per
              vivere la barca con maggiore tranquillita.
            </p>
            <div class="mt-6">
              <Button href="#contatti" label="Richiedi preventivo" />
            </div>
          </div>
        </div>
      </div>
    </div>
    <style>
      .sailing-crossfade {
        animation: sailing-crossfade 12s ease-in-out infinite alternate;
        opacity: 0;
      }

      .sailing-copy {
        transition: opacity 1.8s ease;
      }

      .sailing-copy-greece {
        animation: sailing-copy-greece 12s ease-in-out infinite alternate;
        opacity: 1;
      }

      .sailing-copy-croatia {
        animation: sailing-copy-croatia 12s ease-in-out infinite alternate;
        opacity: 0;
      }

      @keyframes sailing-crossfade {
        0%,
        35% {
          opacity: 0;
        }

        65%,
        100% {
          opacity: 1;
        }
      }

      @keyframes sailing-copy-greece {
        0%,
        35% {
          opacity: 1;
        }

        65%,
        100% {
          opacity: 0;
        }
      }

      @keyframes sailing-copy-croatia {
        0%,
        35% {
          opacity: 0;
        }

        65%,
        100% {
          opacity: 1;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .sailing-crossfade,
        .sailing-copy-greece,
        .sailing-copy-croatia {
          animation: none;
        }

        .sailing-crossfade,
        .sailing-copy-croatia {
          opacity: 0;
        }

        .sailing-copy-greece {
          opacity: 1;
        }
      }
    </style>
  </section>

  <section class="bg-anchor-white px-5 py-14 md:px-8 md:py-16">
    <div class="mx-auto max-w-[1360px]">
      <div class="mx-auto max-w-4xl text-center">
        <div
          class="mx-auto mb-3 flex h-9 w-9 items-center justify-center rounded-full bg-anchor-off-white text-anchor-brass"
          aria-hidden="true"
        >
          <svg
            class="h-[18px] w-[18px]"
            viewBox="0 0 32 32"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M16 3v24"></path>
            <path d="M16 5 7 23h9"></path>
            <path d="M17 9l8 14h-8"></path>
            <path d="M8 28h17"></path>
          </svg>
        </div>
        <h2
          class="text-4xl font-black leading-none text-anchor-navy md:text-5xl"
        >
          Corsi di vela
        </h2>
        <p class="mt-3 text-xs leading-5 text-anchor-steel-grey md:text-sm">
          Percorsi pratici e progressivi per imparare, migliorare e gestire la
          barca in ogni situazione.
        </p>
      </div>

      <div
        class="mt-12 grid items-stretch gap-6 md:mt-14 md:grid-cols-2 lg:grid-cols-3"
      >
        {
          coursePlans.map((plan) => (
            <article
              class:list={[
                "relative flex h-full flex-col overflow-visible rounded-anchor bg-anchor-white text-anchor-navy",
                "border border-anchor-light-grey shadow-[0_18px_55px_rgb(11_31_51_/_0.07)]",
                plan.featured &&
                  "-translate-y-1 border-anchor-brass shadow-[0_22px_70px_rgb(11_31_51_/_0.11)] ring-2 ring-anchor-brass",
              ]}
            >
              {plan.featured && (
                <div class="absolute left-1/2 top-0 z-30 flex -translate-x-1/2 -translate-y-1/2 items-center gap-1 rounded-anchor bg-anchor-brass px-4 py-2 text-[10px] font-black uppercase leading-none text-anchor-navy shadow-[0_10px_30px_rgb(255_184_0_/_0.28)]">
                  <svg
                    class="h-3.5 w-3.5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m12 3 2.6 5.3 5.9.8-4.2 4.1 1 5.8-5.3-2.8L6.7 19l1-5.8-4.2-4.1 5.9-.8L12 3Z" />
                  </svg>
                  PI&Ugrave; RICHIESTO
                </div>
              )}

              <div class="overflow-hidden rounded-t-anchor">
                <img
                  class="h-[145px] w-full object-cover md:h-[160px]"
                  src={plan.image}
                  alt={plan.imageAlt}
                  width="960"
                  height="540"
                  loading="lazy"
                  decoding="async"
                />
              </div>

              <div class="flex flex-1 flex-col px-6 pb-7 text-center">
                <div
                  class:list={[
                    "relative z-10 mx-auto -mt-8 flex h-16 w-16 items-center justify-center rounded-full bg-anchor-white shadow-[0_12px_32px_rgb(11_31_51_/_0.12)]",
                    plan.featured
                      ? "border-2 border-anchor-brass text-anchor-brass"
                      : "border border-anchor-light-grey text-anchor-navy",
                  ]}
                  aria-hidden="true"
                >
                  <span
                    class="course-icon block h-8 w-8"
                    set:html={courseIcons[plan.icon]}
                  />
                </div>

                <h3 class="mt-3 text-2xl font-black leading-tight">
                  {plan.title}
                </h3>
                <p class="mt-1 text-xs font-semibold text-anchor-steel-grey">
                  {plan.subtitle}
                </p>
                <div class="mx-auto mt-3 h-0.5 w-9 rounded-full bg-anchor-brass" />
                <p
                  class:list={[
                    "mt-4 font-bold leading-none tracking-tight text-anchor-navy",
                    plan.price === "Su richiesta"
                      ? "text-3xl md:text-[34px]"
                      : "text-4xl md:text-[42px]",
                  ]}
                  set:html={plan.price}
                />
                <p class="mx-auto mt-3 max-w-[260px] text-xs leading-5 text-anchor-steel-grey">
                  {plan.description}
                </p>

                <div class="mt-5 border-t border-anchor-light-grey pt-3">
                  <ul class="space-y-2 text-left text-xs">
                    {plan.features.map(([feature, value]) => (
                      <li class="grid grid-cols-[1fr_auto] items-center gap-3">
                        <span class="font-semibold leading-4 text-anchor-navy">
                          {feature}
                        </span>
                        <span class="text-[11px] font-black text-anchor-steel-blue">
                          {value}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>

                <a
                  class:list={[
                    "mt-5 inline-flex min-h-10 w-full items-center justify-center rounded-anchor px-5 py-2.5 text-xs font-black transition",
                    plan.featured
                      ? "bg-anchor-brass text-anchor-navy hover:bg-anchor-navy hover:text-anchor-white"
                      : "border border-anchor-navy text-anchor-navy hover:bg-anchor-navy hover:text-anchor-white",
                  ]}
                  href="#contatti"
                >
                  Richiedi informazioni
                </a>
              </div>
            </article>
          ))
        }
      </div>

      <div
        class="mt-7 grid gap-5 rounded-anchor bg-anchor-off-white p-4 text-anchor-navy shadow-[0_16px_50px_rgb(11_31_51_/_0.05)] md:grid-cols-3 md:px-8 md:py-5"
      >
        <div class="flex items-center gap-4">
          <span
            class="trust-icon flex h-10 w-10 shrink-0 items-center justify-center text-anchor-brass"
            set:html={featureIcon}
          />
          <div>
            <p class="text-sm font-black">Istruttori qualificati</p>
            <p class="mt-1 text-xs leading-5 text-anchor-steel-grey">
              Esperienza e sicurezza al primo posto.
            </p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <span
            class="trust-icon flex h-10 w-10 shrink-0 items-center justify-center text-anchor-brass"
            set:html={courseIcons.compass}
          />
          <div>
            <p class="text-sm font-black">Formazione pratica</p>
            <p class="mt-1 text-xs leading-5 text-anchor-steel-grey">
              Uscite reali, barche attrezzate e apprendimento sul campo.
            </p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <span
            class="trust-icon flex h-10 w-10 shrink-0 items-center justify-center text-anchor-brass"
            set:html={courseIcons.waves}
          />
          <div>
            <p class="text-sm font-black">Percorsi progressivi</p>
            <p class="mt-1 text-xs leading-5 text-anchor-steel-grey">
              Adatti al tuo livello e ai tuoi obiettivi.
            </p>
          </div>
        </div>
      </div>

      <style>
        .course-icon svg,
        .trust-icon svg {
          height: 100%;
          width: 100%;
          fill: none;
          stroke: currentColor;
          stroke-linecap: round;
          stroke-linejoin: round;
        }

        .course-icon svg {
          stroke-width: 1.8;
        }

        .trust-icon svg {
          height: 28px;
          width: 28px;
          stroke-width: 1.7;
        }
      </style>
    </div>
  </section>
  <section class="bg-anchor-white px-5 py-20 md:px-8">
    <div
      class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[0.9fr_1.1fr]"
    >
      <TechnicalVisual
        label="Area visuale per dettaglio reale di sartie, terminali e arridatoi"
      />
      <div>
        <SectionHeader
          title="Controlli mirati su standing rigging e punti di usura"
          description="Una verifica tecnica aiuta a individuare segnali di ossidazione, giochi anomali, deformazioni o componenti da programmare per la sostituzione."
        />
        <ul
          class="mt-8 grid gap-4 text-sm font-bold text-anchor-navy sm:grid-cols-2"
        >
          <li
            class="rounded-anchor border border-anchor-light-grey bg-anchor-off-white p-4"
          >
            Sartie e strallo
          </li>
          <li
            class="rounded-anchor border border-anchor-light-grey bg-anchor-off-white p-4"
          >
            Terminali e arridatoi
          </li>
          <li
            class="rounded-anchor border border-anchor-light-grey bg-anchor-off-white p-4"
          >
            Lande e punti di fissaggio
          </li>
          <li
            class="rounded-anchor border border-anchor-light-grey bg-anchor-off-white p-4"
          >
            Cime, drizze e coperta
          </li>
        </ul>
        <div class="mt-8">
          <Button
            href="/servizi/rigging"
            label="Vai alla pagina rigging"
            variant="secondary"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-anchor-navy px-5 py-20 text-anchor-white md:px-8">
    <div class="mx-auto max-w-7xl">
      <SectionHeader
        eyebrow="Metodo"
        title="Come lavoriamo"
        description="Partiamo dal problema reale, valutiamo le priorita e programmiamo l'intervento in modo chiaro."
        tone="dark"
      />
      <div class="mt-12 grid gap-5 md:grid-cols-4">
        {
          [
            "Primo contatto",
            "Verifica tecnica",
            "Intervento programmato",
            "Indicazioni operative",
          ].map((item, index) => (
            <article class="border-t border-anchor-brass pt-5">
              <p class="text-sm font-black text-anchor-brass">
                {String(index + 1).padStart(2, "0")}
              </p>
              <h3 class="mt-4 text-xl font-black">{item}</h3>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="chi-siamo" class="bg-anchor-white px-5 py-20 md:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionHeader
        eyebrow="Chi siamo"
        title="Una realta tecnica nautica a Bari"
      />
      <div class="space-y-5 text-lg leading-8 text-anchor-steel-grey">
        <p>
          Anchor Service lavora al fianco di chi usa la barca a vela e ha
          bisogno di un interlocutore tecnico per rigging, manutenzione e
          controlli a bordo.
        </p>
        <p>
          Il sito mette in evidenza servizi concreti, richieste di ispezione e
          contatti diretti, senza promesse generiche o informazioni non
          confermate.
        </p>
      </div>
    </div>
  </section>

  <ContactSection />
</BaseLayout>
