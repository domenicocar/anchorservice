---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import SailingExperienceContent from "../components/sections/SailingExperienceContent.astro";

const title = "Sailing Experience e corsi di vela | Anchor Service";
const description =
  "Esperienze in barca tra Grecia e Croazia e corsi di vela pratici, dal livello base all'avanzato, con Anchor Service.";
---

<BaseLayout title={title} description={description}>
  <div class="bg-anchor-white pt-32">
    <SailingExperienceContent />
  </div>
  <ContactSection />
</BaseLayout>
