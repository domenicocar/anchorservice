---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { services, siteConfig } from "../../data/site";
import ServiceDetailPage from "../../components/sections/ServiceDetailPage.astro";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const title = service.seo.title;
const description = service.seo.description;
const canonical = new URL(service.href, siteConfig.url).toString();
const ogImage = new URL(service.image, siteConfig.url).toString();
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
>
  <ServiceDetailPage service={service} />
</BaseLayout>
