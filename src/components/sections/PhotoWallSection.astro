const asViewportWidth = (value: string) => value.replace("%", "vw");
---

<section
  class="photo-wall-section bg-anchor-white px-5 pb-24 pt-4 md:px-8 md:pb-28 md:pt-8"
  aria-labelledby="photo-wall-title"
  data-experience-theme-neighbor
>
  <div class="mx-auto max-w-7xl">
    <div id="photo-wall-title">
      <SectionHeader
        title="Esperienza, competenze e lavoro sul campo"
        description="Anchor Service nasce dall’esperienza diretta a bordo e dalla collaborazione con professionisti del settore nautico. Rigging, manutenzione, trasferimenti e assistenza operativa raccontano un lavoro concreto, costruito ogni giorno tra porti, cantieri e mare."
        align="center"
      />
    </div>

    <div class="photo-wall mt-14 overflow-x-clip overflow-y-visible md:mt-16">
      <span class="photo-wall__line" aria-hidden="true"></span>
      {
        galleryImages.map((image) => (
          <figure
            class:list={[
              "photo-wall__item",
              !image.tablet && "photo-wall__item--desktop",
              !image.mobile && "photo-wall__item--not-mobile",
            ]}
            style={`--x:${image.x};--y:${image.y};--w:${image.width};--h:${image.height};--r:${image.rotate};--z:${image.zIndex};--mx:${image.mobile?.x ?? "0"};--my:${image.mobile?.y ?? "0"};--mw:${image.mobile?.width ?? "0"};--mh:${image.mobile?.height ?? "0"};--mr:${image.mobile?.rotate ?? "0deg"};--mz:${image.mobile?.zIndex ?? 1};--op:${image.objectPosition ?? "center"}`}
          >
            <img
              src={`/images/foto/wall/${image.name}-800.webp`}
              srcset={`/images/foto/wall/${image.name}-480.webp 480w, /images/foto/wall/${image.name}-800.webp 800w`}
              sizes={`(max-width: 767px) ${image.mobile ? asViewportWidth(image.mobile.width) : "1px"}, (max-width: 1199px) ${asViewportWidth(image.width)}, (max-width: 1280px) ${asViewportWidth(image.width)}, ${Math.round(Number.parseFloat(image.width) * 12.8)}px`}
              alt={image.alt}
              width={image.intrinsicWidth}
              height={image.intrinsicHeight}
              loading="lazy"
              decoding="async"
              fetchpriority="low"
            />
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .photo-wall {
    position: relative;
    height: 720px;
    border: 0;
    background: transparent;
    box-shadow: none;
  }

  .photo-wall__line {
    position: absolute;
    top: 22px;
    right: 4%;
    width: 112px;
    height: 3px;
    border-radius: var(--radius-anchor);
    background: var(--color-anchor-brass);
  }

  .photo-wall__item {
    position: absolute;
    left: var(--x);
    top: var(--y);
    z-index: var(--z);
    width: var(--w);
    height: var(--h);
    margin: 0;
    overflow: hidden;
    transform: rotate(var(--r));
    border: 5px solid var(--color-anchor-white);
    border-radius: var(--radius-anchor);
    background: var(--color-anchor-light-grey);
    box-shadow: 0 16px 35px rgb(11 31 51 / 0.2);
    transition:
      transform 300ms ease,
      box-shadow 300ms ease;
  }

  .photo-wall__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--op);
  }

  @media (hover: hover) and (pointer: fine) {
    .photo-wall__item:hover {
      z-index: 30;
      transform: rotate(0deg) scale(1.03);
      box-shadow: 0 24px 48px rgb(11 31 51 / 0.28);
    }
  }

  @media (max-width: 1199px) {
    .photo-wall {
      height: 620px;
    }

    .photo-wall__item {
      transform: rotate(var(--r));
    }

    .photo-wall__item--desktop {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .photo-wall {
      display: block;
      height: 720px;
    }

    .photo-wall__line,
    .photo-wall__item--not-mobile {
      display: none;
    }

    .photo-wall__item {
      position: absolute;
      left: var(--mx);
      top: var(--my);
      z-index: var(--mz);
      width: var(--mw);
      height: var(--mh);
      border-width: 3px;
      transform: rotate(var(--mr));
      box-shadow: 0 10px 24px rgb(11 31 51 / 0.16);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-wall__item {
      transition: none;
    }

    .photo-wall__item:hover {
      transform: rotate(var(--r));
    }
  }
</style>
