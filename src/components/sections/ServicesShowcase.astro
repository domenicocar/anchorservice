---
import {
  commercialService,
  featuredService as rigging,
  technicalServices as supportingServices,
} from "../../data/site";

const benefits = [
  {
    title: "Interventi tecnici operativi",
    description: "Valutazioni mirate per le esigenze tecniche di bordo.",
    icon: "shield",
  },
  {
    title: "Supporto a bordo e in porto",
    description:
      "Assistenza durante navigazione, soste tecniche e permanenza in marina.",
    icon: "anchor",
  },
  {
    title: "Esperienza su vela e motore",
    description: "Competenze applicate a yacht a vela e a motore.",
    icon: "wheel",
  },
  {
    title: "Consulenza pratica e concreta",
    description: "Coordinamento tecnico e supporto nelle decisioni operative.",
    icon: "messages",
  },
] as const;

const icons = {
  shield:
    '<svg viewBox="0 0 24 24"><path d="M20 13c0 5-3.5 7.5-8 9-4.5-1.5-8-4-8-9V5l8-3 8 3v8Z"/><path d="m9 12 2 2 4-4"/></svg>',
  anchor:
    '<svg viewBox="0 0 24 24"><path d="M12 22V8"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/><circle cx="12" cy="5" r="3"/></svg>',
  wheel:
    '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/><circle cx="12" cy="12" r="2"/></svg>',
  messages:
    '<svg viewBox="0 0 24 24"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3v-7a4 4 0 0 1-1-2.65V7a4 4 0 0 1 4-4h11a4 4 0 0 1 4 4Z"/><path d="M8 10h.01M12 10h.01M16 10h.01"/></svg>',
  wrench:
    '<svg viewBox="0 0 24 24"><path d="M14.7 6.3a4 4 0 0 0-5-5l2.1 2.1-8.4 8.4a2 2 0 0 0 0 2.8l6 6a2 2 0 0 0 2.8 0l8.4-8.4 2.1 2.1a4 4 0 0 0-5-5l-2.8 2.8-3-3 2.8-2.8Z"/></svg>',
  wind: '<svg viewBox="0 0 24 24"><path d="M12.8 4.6A2 2 0 1 1 14 8H2"/><path d="M17.7 8.6A2.5 2.5 0 1 1 19.5 13H2"/><path d="M9.8 18.4A2 2 0 1 0 11 15H2"/></svg>',
  ship: '<svg viewBox="0 0 24 24"><path d="M12 10.2V6"/><path d="M8 6h8"/><path d="M18 18a6 6 0 0 0 3-5l-9-3-9 3a6 6 0 0 0 3 5"/><path d="M3 22c1.5 0 2.5-1 3-2 .5 1 1.5 2 3 2s2.5-1 3-2c.5 1 1.5 2 3 2s2.5-1 3-2c.5 1 1.5 2 3 2"/></svg>',
  mapPin:
    '<svg viewBox="0 0 24 24"><path d="M20 10c0 5-8 12-8 12S4 15 4 10a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>',
  clipboard:
    '<svg viewBox="0 0 24 24"><rect width="16" height="18" x="4" y="4" rx="2"/><path d="M9 2h6a1 1 0 0 1 1 1v2H8V3a1 1 0 0 1 1-1Z"/><path d="m9 14 2 2 4-4"/></svg>',
  arrow:
    '<svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>',
} as const;
---

<div class="mt-10 space-y-4">
  <div class="grid gap-6 lg:grid-cols-[1.45fr_1fr]">
    <article
      class="grid overflow-hidden rounded-anchor border border-anchor-light-grey border-t-anchor-brass border-t-4 bg-anchor-navy shadow-[0_14px_45px_rgb(11_31_51_/_0.07)] md:h-[330px] md:grid-cols-2"
    >
      <img
        class="h-64 w-full object-cover object-center md:h-[330px]"
        src={rigging.image}
        alt={rigging.imageAlt}
        width={rigging.imageWidth}
        height={rigging.imageHeight}
        style={`object-position: ${rigging.imagePosition || "center center"}`}
        loading="lazy"
        decoding="async"
        sizes="(min-width: 1024px) 50vw, 100vw"
      />
      <div
        class="flex flex-col justify-center bg-anchor-navy p-6 text-anchor-white"
      >
        <p
          class="w-fit rounded-anchor bg-anchor-brass px-3 py-2 text-[10px] font-bold uppercase leading-none text-anchor-navy"
        >
          Servizio principale
        </p>
        <h3 class="mt-4 text-2xl font-bold leading-tight text-anchor-white">
          {rigging.title}
        </h3>
        <span class="mt-3 h-0.5 w-10 bg-anchor-brass" aria-hidden="true"></span>
        <p class="mt-3 text-sm leading-5 text-anchor-light-grey">
          {rigging.shortDescription}
        </p>
        <a
          class="mt-5 inline-flex min-h-11 w-full items-center justify-center gap-4 rounded-anchor border border-anchor-brass px-5 py-3 text-xs font-semibold text-anchor-white transition-colors hover:bg-anchor-brass hover:text-anchor-navy sm:w-fit"
          href={rigging.href}
        >
          Scopri il servizio
          <span
            class="showcase-icon h-4 w-4 text-anchor-brass"
            set:html={icons.arrow}
          />
        </a>
      </div>
    </article>

    <aside
      class="rounded-anchor border border-anchor-light-grey bg-anchor-white px-6 py-3 shadow-[0_14px_45px_rgb(11_31_51_/_0.05)]"
      aria-label="Punti di forza del supporto Anchor Service"
    >
      {
        benefits.map((benefit, index) => (
          <div
            class:list={[
              "grid grid-cols-[42px_1px_1fr] items-center gap-4 py-4",
              index < benefits.length - 1 &&
                "border-b border-anchor-light-grey",
            ]}
          >
            <span
              class="showcase-icon mx-auto h-7 w-7 text-anchor-navy"
              set:html={icons[benefit.icon]}
            />
            <span class="h-8 bg-anchor-brass" aria-hidden="true" />
            <div>
              <p class="text-sm font-semibold leading-tight text-anchor-navy">
                {benefit.title}
              </p>
              <p class="mt-1 text-xs leading-5 text-anchor-steel-grey">
                {benefit.description}
              </p>
            </div>
          </div>
        ))
      }
    </aside>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-5">
    {
      supportingServices.map((service) => (
        <article class="h-full">
          <a
            class="group relative flex h-[310px] overflow-hidden rounded-anchor bg-anchor-navy text-anchor-white shadow-[0_12px_35px_rgb(11_31_51_/_0.08)] md:h-[330px] xl:h-[350px]"
            href={service.href}
            aria-label={`Scopri di più: ${service.title}`}
          >
            <img
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
              src={service.image}
              alt={service.imageAlt}
              width={service.imageWidth}
              height={service.imageHeight}
              loading="lazy"
              decoding="async"
              sizes="(min-width: 1280px) 18vw, (min-width: 768px) 45vw, 100vw"
              style={`object-position: ${service.imagePosition || "center center"}`}
            />
            <span
              class="absolute inset-0 bg-gradient-to-t from-anchor-navy via-anchor-navy/80 via-45% to-transparent to-85% transition-colors group-hover:bg-anchor-navy/10"
              aria-hidden="true"
            />
            <span class="relative z-10 mt-auto flex min-h-[62%] w-full flex-col justify-end p-5">
              <span
                class="showcase-icon mb-4 h-7 w-7 text-anchor-brass"
                set:html={icons[service.homepageIcon]}
              />
              <h3 class="text-xl font-semibold leading-[1.12] text-anchor-white">
                {service.title}
              </h3>
              <span class="mt-3 text-sm leading-5 text-anchor-white/90">
                {service.shortDescription}
              </span>
              <span class="mt-4 inline-flex min-h-9 items-center gap-3 text-xs font-semibold text-anchor-white">
                Scopri di più
                <span
                  class="showcase-icon h-4 w-4 text-anchor-brass transition-transform duration-300 group-hover:translate-x-1"
                  set:html={icons.arrow}
                />
              </span>
            </span>
          </a>
        </article>
      ))
    }
  </div>

  <article
    class="grid gap-4 rounded-anchor border border-anchor-light-grey bg-anchor-off-white px-5 py-4 text-anchor-navy shadow-[0_12px_35px_rgb(11_31_51_/_0.05)] md:grid-cols-[auto_1fr_auto] md:items-center md:px-8 lg:grid-cols-[auto_minmax(0,560px)_auto] lg:justify-center lg:gap-8"
  >
    <span
      class="showcase-icon flex h-11 w-11 shrink-0 items-center justify-center text-anchor-navy"
      set:html={icons.wheel}
      aria-hidden="true"
    />
    <div>
      <h3 class="text-sm font-semibold text-anchor-navy">
        {commercialService.title}
      </h3>
      <p class="mt-1 max-w-2xl text-xs leading-5 text-anchor-steel-grey">
        {commercialService.shortDescription}
      </p>
    </div>
    <a
      class="inline-flex min-h-11 w-full items-center justify-center gap-5 rounded-anchor bg-anchor-navy px-6 py-3 text-xs font-semibold text-anchor-white transition-colors hover:bg-anchor-steel-blue md:w-auto"
      href={commercialService.href}
    >
      Scopri i servizi
      <span
        class="showcase-icon h-4 w-4 text-anchor-brass"
        set:html={icons.arrow}
      />
    </a>
  </article>
</div>

<style>
  .showcase-icon :global(svg) {
    height: 100%;
    width: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
</style>
