---
import type { Service } from "../../data/site";
import { siteConfig } from "../../data/site";
import Button from "../ui/Button.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import ServiceDetailHero from "./ServiceDetailHero.astro";

interface Props {
  service: Service;
}

const { service } = Astro.props;
---

<ServiceDetailHero
  eyebrow={service.category || "Servizio tecnico"}
  title={service.title}
  description={service.shortDescription}
  image={service.image}
  imageAlt={service.imageAlt}
  imageWidth={service.imageWidth}
  imageHeight={service.imageHeight}
  imagePosition={service.imagePosition}
  breadcrumb={[
    { label: "Home", href: "/" },
    { label: "Servizi", href: "/servizi" },
    { label: service.title },
  ]}
  actions={[
    { href: "/#contatti", label: "Richiedi informazioni" },
    ...(siteConfig.phoneHref
      ? [
          {
            href: siteConfig.phoneHref,
            label: "Chiama ora",
            variant: "ghost" as const,
          },
        ]
      : []),
  ]}
/>

<section class="px-5 py-20 md:px-8">
  <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.72fr_1.28fr]">
    <SectionHeader
      eyebrow="Il servizio"
      title="Un supporto costruito sulle esigenze della barca"
      description={service.description}
    />
    <div
      class="rounded-anchor border border-anchor-light-grey bg-anchor-white p-6 md:p-8"
    >
      <h2 class="text-2xl font-semibold text-anchor-navy">Cosa comprende</h2>
      <ul class="mt-6 grid gap-3 sm:grid-cols-2">
        {
          service.items.map((item) => (
            <li class="flex items-start gap-3 border-b border-anchor-light-grey pb-3 text-sm leading-6 text-anchor-text">
              <span
                class="mt-2 h-1.5 w-1.5 shrink-0 rounded-anchor bg-anchor-brass"
                aria-hidden="true"
              />
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<section class="bg-anchor-off-white px-5 py-20 md:px-8">
  <div class="mx-auto max-w-7xl">
    <SectionHeader
      eyebrow="Metodo"
      title="Come lavoriamo"
      description="Partiamo dalla richiesta reale, definiamo le priorità e coordiniamo le attività in modo chiaro."
    />
    <ol class="mt-10 grid gap-5 md:grid-cols-3">
      {
        service.method.map((step, index) => (
          <li class="rounded-anchor border border-anchor-light-grey bg-anchor-white p-6">
            <p class="text-xs font-semibold text-anchor-brass">
              {String(index + 1).padStart(2, "0")}
            </p>
            <h3 class="mt-3 text-lg font-semibold text-anchor-navy">
              {step.title}
            </h3>
            <p class="mt-2 text-sm leading-6 text-anchor-steel-grey">
              {step.description}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<section class="bg-anchor-white px-5 py-20 md:px-8">
  <div
    class="mx-auto grid max-w-7xl items-center gap-8 md:grid-cols-[1fr_auto]"
  >
    <SectionHeader
      eyebrow="Contatto tecnico"
      title="Descrivi la barca e il problema da valutare."
      description="Indica tipo di barca, lunghezza, porto o marina e il servizio richiesto: ti aiuteremo a capire il primo passo utile."
    />
    <div class="flex flex-wrap gap-3 md:justify-end">
      <Button href="/#contatti" label="Richiedi informazioni" />
      {
        siteConfig.whatsappHref && (
          <Button
            href={siteConfig.whatsappHref}
            label="WhatsApp"
            variant="whatsapp"
          />
        )
      }
    </div>
  </div>
</section>
